  "keyFeatures": [
    "Koa-style middleware chains per SMTP phase",
    "Simple plugin system with no registry or lifecycle hooks",
    "Built-in plugins for common tasks (auth, filtering, logging)",
    "TypeScript-first with complete type safety",
    "Native Bun performance with zero Node.js overhead",
    "Composable middleware for connect, auth, mailFrom, rcptTo, data, and close phases"
  ],
  "publicApiSurface": [
    "Fumi - Main framework class",
    "use() - Register plugins",
    "onConnect() - Add connect phase middleware",
    "onAuth() - Add authentication middleware",
    "onMailFrom() - Add MAIL FROM phase middleware",
    "onRcptTo() - Add RCPT TO phase middleware",
    "onData() - Add data phase middleware",
    "onClose() - Add close phase middleware",
    "listen() - Start SMTP server",
    "close() - Stop SMTP server",
    "logger() - Logging plugin",
    "maxSize() - Message size limit plugin",
    "requireTls() - TLS enforcement plugin",
    "denylist() - IP blocking plugin",
    "rcptFilter() - Recipient filtering plugin",
    "senderBlock() - Sender blocking plugin"
  ]
